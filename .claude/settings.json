{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(pwd)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(nc *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Bash(node -e *)",
      "Bash(bash -c *)",
      "Bash(sh -c *)",
      "Bash(eval *)",
      "Bash(exec *)",
      "Bash(rm -rf *)",
      "Bash(chmod 777 *)",
      "Bash(osascript *)",
      "Bash(launchctl *)",
      "Bash(security *)",
      "Bash(defaults write *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.env.staging)",
      "Read(**/secrets/**)",
      "Read(**/secret/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/credentials)",
      "Read(**/credentials.*)",
      "Read(**/config/database.yml)",
      "Read(**/database.env)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "WebFetch(domain:*)"
    ],
    "ask": [
      "Bash(find . -name *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(npm install *)",
      "Bash(npm run build *)",
      "Bash(npm run test *)",
      "Bash(npm run deploy *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(pip install *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git reset *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(docker-compose *)",
      "Write(**/*)",
      "Edit(**/*)"
    ]
  },
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1"
  }
}

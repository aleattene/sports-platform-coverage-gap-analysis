# Pipeline control
APP_ENV=development
FETCH_REGISTRY_DATA=false
FETCH_PLATFORM_DATA=false

# Platform API (required when FETCH_PLATFORM_DATA=true)
PLATFORM_NAME=example_platform
PLATFORM_BASE_URL=
PLATFORM_ORGS_ENDPOINT=
PLATFORM_REQUEST_DELAY_S=10
PLATFORM_MAX_RETRIES=3
PLATFORM_REQUEST_TIMEOUT_S=30

# Registry (required when FETCH_REGISTRY_DATA=true)
REGISTRY_NAME=example_registry
SOURCE_URL=
SOURCE_REGION_SELECT_NAME=
SOURCE_PROVINCE_SELECT_NAME=
SOURCE_PROVINCES_TASK_KEY=
PW_BETWEEN_REQUESTS_MS=5000
DEV_MODE=false